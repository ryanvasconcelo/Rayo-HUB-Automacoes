{
    "name": "rayo-monorepo",
    "private": true,
    "version": "1.0.0",
    "description": "Rayo Monorepo Workspace",
    "engines": {
        "node": ">=18.0.0"
    },
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev:frontend": "npm run dev --workspace=apps/rayo",
        "dev:backend": "npm run dev --workspace=apps/rayo-server",
        "build:frontend": "npm run build --workspace=apps/rayo",
        "build:subvencoes": "npm run build --workspace=apps/subvencoes",
        "build:all": "npm run build:frontend && npm run build:subvencoes",
        "install:all": "npm install",
        "start": "concurrently --names \"rayo,sefaz\" --prefix-colors \"cyan,yellow\" \"npm run start --workspace=apps/rayo-server\" \"node ../subvencoes/server/index.js\""
    },
    "devDependencies": {
        "concurrently": "^9.2.1"
    }
}
