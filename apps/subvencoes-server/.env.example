# ──────────────────────────────────────────────────
# SEFAZ-AM Downloader — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ──────────────────────────────────────────────────

# Porta do servidor Express (padrão: 3002)
PORT=3002

# Inscrição Estadual do contribuinte no AM
SEFAZ_IE=041504550

# Caminho absoluto para o certificado A1 (.pfx)
# Windows: C:\Users\Suelen\Desktop\certificado.pfx
# macOS/Linux: /Users/usuario/certs/certificado.pfx
SEFAZ_PFX_PATH=C:\Users\Suelen\Desktop\certificado.pfx

# Senha/passphrase do certificado digital
SEFAZ_PFX_SENHA=senha_do_certificado

# CFOP padrão para filtro no portal (opcional)
# Exemplos: 6109, 6110 — deixe vazio para baixar todos
SEFAZ_CFOP=

# Modo headless: "true" = sem janela (produção) | "false" = com janela (debug)
SEFAZ_HEADLESS=false
